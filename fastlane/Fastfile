default_platform(:ios)

APP_ID  = "com.shaver.flowtear"
PROFILE = "match AppStore com.shaver.flowtear"   # used only by the match lanes

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: ENV.fetch("ASC_KEY_FILEPATH"),
    in_house: false
  )
end

platform :ios do
  # ── ACTIVE (cloud-signed pipeline) ──────────────────────────────────────────
  # The workflow archives + exports with xcodebuild automatic signing; this lane
  # just uploads the finished .ipa (path in IPA_PATH) to TestFlight.
  desc "Upload an already-exported .ipa to TestFlight."
  lane :upload_testflight do
    pilot(
      api_key: asc_api_key,
      ipa: ENV.fetch("IPA_PATH"),
      skip_submission: true,
      # Wait for Apple's post-upload PROCESSING and fail loudly if it's rejected —
      # an "uploaded" build that never appears in TestFlight failed processing, and
      # skipping the wait hides exactly that error.
      skip_waiting_for_build_processing: false
    )
  end

  # ── FUTURE (fastlane match) — unused by the cloud-signed flow. Bootstrap the
  #    signing repo first (bootstrap-signing.yml → `certs`), then point
  #    testflight.yml at `beta` to stop the certificate-cap churn. ─────────────
  desc "Create/refresh the shared App Store signing assets in the match repo."
  lane :certs do
    setup_ci
    ENV["MATCH_READONLY"] = "false"   # setup_ci turns readonly on; bootstrap must create/store
    match(type: "appstore", app_identifier: APP_ID, api_key: asc_api_key, readonly: false)
  end

  desc "Build with match signing and upload to TestFlight."
  lane :beta do
    setup_ci
    key = asc_api_key
    match(type: "appstore", app_identifier: APP_ID, api_key: key, readonly: true)
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Flowtear.xcodeproj",
      targets: ["Flowtear"],
      team_id: ENV.fetch("APPLE_TEAM_ID"),
      code_sign_identity: "Apple Distribution",
      profile_name: PROFILE
    )
    build_app(
      project: "Flowtear.xcodeproj",
      scheme: "Flowtear",
      configuration: "Release",
      output_directory: ENV.fetch("RUNNER_TEMP", "."),
      output_name: "Flowtear.ipa",
      export_method: "app-store",
      xcargs: "BUILD_NUMBER=#{ENV.fetch('BUILD_NUMBER', '1')}",
      export_options: {
        signingStyle: "manual",
        teamID: ENV.fetch("APPLE_TEAM_ID"),
        provisioningProfiles: { APP_ID => PROFILE }
      }
    )
    pilot(
      api_key: key,
      ipa: lane_context[SharedValues::IPA_OUTPUT_PATH],
      skip_submission: true,
      skip_waiting_for_build_processing: true
    )
  end
end
