default_platform(:ios)

APP_ID  = "com.shaver.flowtear"
PROFILE = "match AppStore com.shaver.flowtear"   # the profile name match creates

# App Store Connect API key, read from the env the workflows set.
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: ENV.fetch("ASC_KEY_FILEPATH"),
    in_house: false
  )
end

platform :ios do
  # BOOTSTRAP — run once (the bootstrap-signing workflow, or locally). Creates the
  # shared Apple Distribution cert + App Store profile and pushes them, encrypted
  # with MATCH_PASSWORD, to the match repo. readonly:false = allowed to create.
  desc "Create/refresh the shared App Store signing assets in the match repo."
  lane :certs do
    setup_ci
    match(type: "appstore", app_identifier: APP_ID, api_key: asc_api_key, readonly: false)
  end

  # RELEASE — fetch the shared signing assets (never creates), build, upload.
  desc "Build with match signing and upload to TestFlight."
  lane :beta do
    setup_ci                                   # ephemeral keychain for match on CI
    key = asc_api_key
    match(type: "appstore", app_identifier: APP_ID, api_key: key, readonly: true)

    # Point the freshly xcodegen'd project at the match profile (manual signing).
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Flowtear.xcodeproj",
      targets: ["Flowtear"],
      team_id: ENV.fetch("APPLE_TEAM_ID"),
      code_sign_identity: "Apple Distribution",
      profile_name: PROFILE
    )

    build_app(
      project: "Flowtear.xcodeproj",
      scheme: "Flowtear",
      configuration: "Release",
      output_directory: ENV.fetch("RUNNER_TEMP", "."),
      output_name: "Flowtear.ipa",
      export_method: "app-store",
      # unique, increasing build number from the CI run number
      xcargs: "BUILD_NUMBER=#{ENV.fetch('BUILD_NUMBER', '1')}",
      export_options: {
        signingStyle: "manual",
        teamID: ENV.fetch("APPLE_TEAM_ID"),
        provisioningProfiles: { APP_ID => PROFILE }
      }
    )

    pilot(
      api_key: key,
      ipa: lane_context[SharedValues::IPA_OUTPUT_PATH],
      skip_submission: true,
      skip_waiting_for_build_processing: true
    )
  end
end
